{
  "name": "eventhub",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @eventhub/api dev",
    "dev:web": "pnpm --filter @eventhub/web dev",
    "build:api": "pnpm --filter @eventhub/api build",
    "build:web": "pnpm --filter @eventhub/web build",
    "build:libs": "pnpm --filter @eventhub/shared-types build && pnpm --filter @eventhub/shared-utils build",
    "build": "pnpm run build:libs && pnpm --filter @eventhub/api exec prisma generate --schema=../../prisma/schema.prisma && pnpm --filter @eventhub/api build",
    "start": "prisma migrate deploy --schema=prisma/schema.prisma && node apps/api/dist/main.js",
    "build:railway": "pnpm run build",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio --schema=prisma/schema.prisma",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "format": "prettier --write \"**/*.{ts,js,json,html,scss}\""
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "prisma": "^6.19.3",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  }
}
