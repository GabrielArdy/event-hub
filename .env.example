# App
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:4200
COOKIE_SECRET=change-this-to-a-random-32-char-string-min

# JWT
JWT_ACCESS_SECRET=access-secret-change-in-production
JWT_REFRESH_SECRET=refresh-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# QR Token
QR_TOKEN_SECRET=qr-secret-change-in-production-min-32chars

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eventhub

# Redis
REDIS_URL=redis://:redis_password@localhost:6379

# Internal service token (M2M)
INTERNAL_SERVICE_TOKEN=change-this-internal-token

# Cloudflare R2 (S3-compatible storage)
# Endpoint format: https://<account-id>.r2.cloudflarestorage.com
STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=r2-access-key-id
STORAGE_SECRET_ACCESS_KEY=r2-secret-access-key
STORAGE_BUCKET_NAME=eventhub-storage
# Public R2 custom domain (enable "Public Access" on the bucket first)
STORAGE_PUBLIC_URL=https://storage.eventhub.id

# Midtrans
MIDTRANS_SERVER_KEY=SB-Mid-server-xxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxx
MIDTRANS_IS_PRODUCTION=false

# Xendit (fallback)
XENDIT_SECRET_KEY=xnd_development_xxx

# Resend (email)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@eventhub.id

# Firebase FCM
FIREBASE_PROJECT_ID=eventhub-xxx
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxx\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@eventhub-xxx.iam.gserviceaccount.com

# SMS (Zenziva)
ZENZIVA_USER_KEY=your-userkey
ZENZIVA_PASSWORD=your-password

# Bull Board
BULL_BOARD_USER=admin
BULL_BOARD_PASSWORD=change-this

# Sentry
SENTRY_DSN=
